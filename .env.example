# --- Fotos: Cloudinary (unsigned upload) ---
# 1. cloudinary.com -> kostenloser Account
# 2. Settings -> Upload -> Add upload preset -> Signing Mode: "Unsigned"
# 3. Cloud-Name und Preset-Name hier eintragen
VITE_CLOUDINARY_CLOUD=
VITE_CLOUDINARY_PRESET=

# --- Daten: Google Apps Script Web-App (Soll-Ist + Foto-Index) ---
# Siehe apps-script/Code.gs und README. Nach "Deploy -> Web-App" die URL hier eintragen.
VITE_DATA_API=

# --- Optional: gemeinsames Trip-Passwort (leer = kein Login) ---
VITE_TRIP_PASSWORD=

# --- Live-Push: oeffentlicher VAPID-Schluessel (privater liegt im Sende-Dienst) ---
# Einrichtung siehe PUSH-SETUP.md. Leer = Push-Funktion inaktiv (kein Fehler).
VITE_VAPID_PUBLIC_KEY=
